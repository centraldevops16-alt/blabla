#!/bin/bash

# Get all file-share ARNs
aws storagegateway list-file-shares \
  --query 'FileShareInfoList[].FileShareARN' \
  --output text |
  while read -r arn; do
    if [ -z "$arn" ]; then
      continue
    fi

    share_id=$(echo "$arn" | awk -F'/' '{print $2}')

    # Query both ReadBytes and WriteBytes for this file share
    resp=$(aws cloudwatch get-metric-data \
      --metric-data-queries '[
        {
          "Id": "readbytes",
          "MetricStat": {
            "Metric": {
              "Namespace": "AWS/StorageGateway",
              "MetricName": "ReadBytes",
              "Dimensions": [
                { "Name": "FileShareId", "Value": "'"$share_id"'" }
              ]
            },
            "Period": 3600,
            "Stat": "Sum"
          }
        },
        {
          "Id": "writebytes",
          "MetricStat": {
            "Metric": "AWS/StorageGateway",
            "MetricName": "WriteBytes",
            "Dimensions": [
              { "Name": "FileShareId", "Value": "'"$share_id"'" }
            ]
          },
          "Period": 3600,
          "Stat": "Sum"
        }
      ]' \
      --start-time "$(date -u -d '14 days ago' +%Y-%m-%dT00:00:00Z)" \
      --end-time "$(date -u +%Y-%m-%dT23:59:59Z)" \
      --output json)

    # Extract max value for ReadBytes (fallback to 0)
    max_read=$(echo "$resp" | \
      grep '"Id":"readbytes"' -A 10 | \
      grep -E 'Values' | \
      grep -E '\[.*\]' | \
      grep -E -o '[0-9]+(\.[0-9]+)?' | \
      sort -n | tail -1 | head -1)
    max_read=${max_read:-0}

    # Extract max value for WriteBytes (fallback to 0)
    max_write=$(echo "$resp" | \
      grep '"Id":"writebytes"' -A 10 | \
      grep -E 'Values' | \
      grep -E '\[.*\]' | \
      grep -E -o '[0-9]+(\.[0-9]+)?' | \
      sort -n | tail -1 | head -1)
    max_write=${max_write:-0}

    # If both metrics are 0, treat as unused
    if (( $(echo "$max_read == 0" | bc -l) )) && (( $(echo "$max_write == 0" | bc -l) )); then
      echo "UNUSED (no ReadBytes + no WriteBytes in last 14d): $arn"
    fi
  done
