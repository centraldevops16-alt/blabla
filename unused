#!/bin/bash

#
# Single account, single region, exactly 2 gateways (hardcoded)
#

region="ap-south-1"   # edit as needed

# Hardcode your two gateway ARNs here
gateway_arns=(
  "arn:aws:storagegateway:ap-south-1:123456789012:gateway/sgw-12345678"
  "arn:aws:storagegateway:ap-south-1:123456789012:gateway/sgw-87654321"
)

query_file="metric-data-query.json"
tmp_file="/tmp/storagegateway.shares.$$"

echo "=== REGION: $region (2 gateways, hardcoded) ==="

for gw_arn in "${gateway_arns[@]}"; do
  echo "GATEWAY: $gw_arn"

  # List all file shares for this gateway
  aws storagegateway list-file-shares \
    --region "$region" \
    --gateway-arn "$gw_arn" \
    --query 'FileShareInfoList[].FileShareARN' \
    --output text > "$tmp_file"

  while IFS= read -r arn; do
    if [ -z "$arn" ]; then
      continue
    fi

    share_id=$(echo "$arn" | awk -F'/' '{print $NF}')

    # Write metric-data query JSON for this file share
    cat > "$query_file" << EOF
[
  {
    "Id": "readbytes",
    "MetricStat": {
      "Metric": {
        "Namespace": "AWS/StorageGateway",
        "MetricName": "ReadBytes",
        "Dimensions": [
          { "Name": "FileShareId", "Value": "$share_id" }
        ]
      },
      "Period": 3600,
      "Stat": "Sum"
    }
  },
  {
    "Id": "writebytes",
    "MetricStat": {
      "Metric": {
        "Namespace": "AWS/StorageGateway",
        "MetricName": "WriteBytes",
        "Dimensions": [
          { "Name": "FileShareId", "Value": "$share_id" }
        ]
      },
      "Period": 3600,
      "Stat": "Sum"
    }
  }
]
EOF

    resp=$(aws cloudwatch get-metric-data \
      --region "$region" \
      --metric-data-queries "file://$PWD/$query_file" \
      --start-time "$(date -u -d '14 days ago' +%Y-%m-%dT00:00:00Z)" \
      --end-time "$(date -u +%Y-%m-%dT23:59:59Z)" \
      --output json)

    # ReadBytes
    max_read=$(echo "$resp" | \
      grep '"Id":"readbytes"' -A 10 | \
      grep -E 'Values' | \
      grep -E '\[.*\]' | \
      grep -E -o '[0-9]+' | \
      sort -n | tail -1 | head -1)
    max_read=${max_read:-0}

    # WriteBytes
    max_write=$(echo "$resp" | \
      grep '"Id":"writebytes"' -A 10 | \
      grep -E 'Values' | \
      grep -E '\[.*\]' | \
      grep -E -o '[0-9]+' | \
      sort -n | tail -1 | head -1)
    max_write=${max_write:-0}

    if [ "$max_read" -eq 0 ] && [ "$max_write" -eq 0 ]; then
      echo "UNUSED (no ReadBytes + no WriteBytes in last 14d): $arn"
    fi
  done < "$tmp_file"

done

# Cleanup
rm -f "$tmp_file" metric-data-query.json
