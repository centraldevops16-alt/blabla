CHARSET = "UTF-8"

def send_notification_email(subject: str, body_text: str, body_html: str, to_addresses: list[str]):
    """Send an SES email with both text and HTML bodies."""
    if not to_addresses:
        logger.warning("No SES recipient addresses; skipping email")
        return

    try:
        ses.send_email(
            Source=SES_SOURCE_EMAIL,
            Destination={"ToAddresses": to_addresses},
            Message={
                "Subject": {"Data": subject, "Charset": CHARSET},
                "Body": {
                    "Text": {"Data": body_text, "Charset": CHARSET},
                    "Html": {"Data": body_html, "Charset": CHARSET},
                },
            },
        )
        logger.info("Notification email sent to %s", to_addresses)
    except ClientError as e:
        logger.error("Error sending SES email: %s", str(e))
