python
#!/usr/bin/env python3
"""
One-time S3 cleanup script: Delete STANDARD class objects >6 months old in buckets matching 'access-logs' or 'athena-logs'.
Uses boto3. Run with AWS credentials having s3:ListBuckets, s3:GetBucketInventoryConfiguration, s3:PutBucketInventoryConfiguration, 
athena:*, s3control:CreateJob, s3:PutObject, s3:GetObject, s3:DeleteObject, iam:PassRole.

Prerequisites:
- AWS CLI configured or env vars.
- Create IAM role for Batch Ops: https://docs.aws.amazon.com/AmazonS3/latest/userguide/batch-ops-create-job.html#batch-ops-iam-role
  Name it 'S3BatchOperations_DeleteRole' with trust policy for batchoperations.s3.amazonaws.com and DeleteObject policy.

Adjust variables below.
"""

import boto3
import json
from datetime import datetime, timedelta
from botocore.exceptions import ClientError
import csv
import io

# CONFIG - Customize these
INVENTORY_BUCKET = 'your-central-inventory-bucket'  # Create this bucket first
INVENTORY_CONFIG_ID = 'cleanup-inventory-1'
INVENTORY_FREQUENCY = 'Weekly'
ATHENA_DB = 'cleanup_db'
ATHENA_TABLE = 's3_inventory'
ATHENA_OUTPUT_LOCATION = f's3://{INVENTORY_BUCKET}/athena-results/'
BATCH_MANIFEST_LOCATION = f's3://{INVENTORY_BUCKET}/manifests/cleanup-manifest.csv'
BATCH_REPORT_BUCKET = INVENTORY_BUCKET
BATCH_ROLE_ARN = 'arn:aws:iam::YOUR-ACCOUNT:role/S3BatchOperations_DeleteRole'  # Update account/role
CUTOFF_DATE = (datetime.now() - timedelta(days=183)).strftime('%Y-%m-%d')  # ~6 months ago
LIKE_PATTERNS = ['access-logs', 'athena-logs']  # Bucket name contains these

s3 = boto3.client('s3')
s3control = boto3.client('s3control')
athena = boto3.client('athena')
glue = boto3.client('glue')  # Optional for crawler
account_id = boto3.client('sts').get_caller_identity()['Account']

print("Step 0: Listing matching buckets...")

# Step 0: Find matching buckets
response = s3.list_buckets()
matching_buckets = [
    b['Name'] for b in response['Buckets']
    if any(pattern in b['Name'] for pattern in LIKE_PATTERNS)
]
print(f"Found {len(matching_buckets)} matching buckets: {matching_buckets}")

# Step 1: Enable Inventory on each bucket (idempotent check first)
print("\nStep 1: Enabling S3 Inventory...")
inventory_config = {
    'Id': INVENTORY_CONFIG_ID,
    'IsEnabled': 'true',
    'Destination': {
        'S3BucketDestination': {
            'AccountId': account_id,
            'Format': 'Parquet',
            'Bucket': f'arn:aws:s3:::{INVENTORY_BUCKET}',
            'Prefix': 'inventory'
        }
    },
    'Schedule': {'Frequency': INVENTORY_FREQUENCY},
    'IncludedObjectVersions': 'Current',
    'OptionalFields': [
        'Size', 'LastModifiedDate', 'StorageClass', 'ETag',
        'EncryptionStatus', 'ObjectLockRetainUntilDate'
    ]
}
for bucket in matching_buckets:
    try:
        s3.get_bucket_inventory_configuration(Bucket=bucket, Id=INVENTORY_CONFIG_ID)
        print(f"Inventory already exists on {bucket}")
    except ClientError as e:
        if e.response['Error']['Code'] == 'NoSuchConfiguration':
            s3.put_bucket_inventory_configuration(Bucket=bucket, InventoryConfiguration=inventory_config)
            print(f"Enabled inventory on {bucket}")
        else:
            raise

print("Wait 24-48h for inventory reports, then run Step 2+ manually or automate polling.")

# --- After inventory ready, run below ---

print("\nStep 2: Create Athena table (run once, assumes Glue DB exists or create it)")
table_ddl = f"""
CREATE EXTERNAL TABLE IF NOT EXISTS `{ATHENA_DB}`.`{ATHENA_TABLE}` (
  `bucket` string,
  `key` string,
  `versionId` string,
  `isLatest` boolean,
  `isDeleteMarker` boolean,
  `size` bigint,
  `lastModifiedDate` bigint,
  `eTag` string,
  `storageClass` string,
  `isMultipartUploaded` boolean,
  `replicationStatus` string,
  `encryptionStatus` string,
  `objectLockRetainUntilDate` bigint,
  `objectLockMode` string,
  `objectLockLegalHoldStatus` string,
  `intelligentTieringAccessTier` string,
  `storageClassAnalysisMetadata` struct <
    storageClassAnalysisSchemaVersion:string
  >
)
PARTITIONED BY (
  `configId` string,
  `reportDate` string
)
ROW FORMAT SERDE 'org.apache.hadoop.hive.ql.io.parquet.serde.ParquetHiveSerDe'
STORED AS INPUTFORMAT 'org.apache.hadoop.hive.ql.io.parquet.MapredParquetInputFormat'
OUTPUTFORMAT 'org.apache.hadoop.hive.ql.io.parquet.MapredParquetOutputFormat'
LOCATION 's3://{INVENTORY_BUCKET}/inventory/'
TBLPROPERTIES ('parquet.compress'='SNAPPY')
"""
athena.start_query_execution(
    QueryString=table_ddl,
    QueryExecutionContext={'Database': ATHENA_DB},
    ResultConfiguration={'OutputLocation': ATHENA_OUTPUT_LOCATION}
)
print("Athena table created. Run MSCK REPAIR TABLE or Glue crawler for partitions.")

# Step 3: Query for targets and generate CSV manifest
print("\nStep 3: Running Athena query for targets...")
athena_query = f"""
SELECT bucket, `key`
FROM `{ATHENA_DB}`.`{ATHENA_TABLE}`
WHERE (`bucket` LIKE '%access-logs%' OR `bucket` LIKE '%athena-logs%')
  AND storageClass = 'STANDARD'
  AND from_unixtime(lastModifiedDate/1000) < date('{CUTOFF_DATE}')
  AND isLatest = true
  AND isDeleteMarker = false
"""
query_exec_id = athena.start_query_execution(
    QueryString=athena_query,
    QueryExecutionContext={'Database': ATHENA_DB},
    ResultConfiguration={'OutputLocation': ATHENA_OUTPUT_LOCATION}
).get('QueryExecutionId')

# Wait for query (simple poll; prod use waiter)
import time
while True:
    status = athena.get_query_execution(QueryExecutionId=query_exec_id)['QueryExecution']['Status']['State']
    if status in ['SUCCEEDED', 'FAILED', 'CANCELLED']:
        break
    time.sleep(5)
if status != 'SUCCEEDED':
    raise Exception(f"Query failed: {status}")

# Download results and format as Batch manifest CSV (bucket,key)
result_s3_key = f"athena-results/{query_exec_id}.csv"  # Adjust if needed
response = s3.get_object(Bucket=INVENTORY_BUCKET, Key=result_s3_key)
csv_content = response['Body'].read().decode('utf-8')
reader = csv.reader(io.StringIO(csv_content))
rows = [row for row in reader if len(row) >= 2]  # Skip header

manifest_content = io.StringIO()
writer = csv.writer(manifest_content)
writer.writerow(['Bucket', 'Key'])  # Header required
for row in rows:
    bucket, key = row[0], row[1]
    writer.writerow([bucket, key])

s3.put_object(
    Bucket=INVENTORY_BUCKET,
    Key='manifests/cleanup-manifest.csv',
    Body=manifest_content.getvalue(),
    ContentType='text/csv'
)
num_objects = len(rows)
print(f"Generated manifest with {num_objects} objects at {BATCH_MANIFEST_LOCATION}")

# Step 4: Create S3 Batch Operations Delete Job
print("\nStep 4: Creating Batch Delete Job...")
job_config = {
    'AccountId': account_id,
    'Operation': {
        'S3DeleteObject': {}  # Simple delete
    },
    'Manifest': {
        'Spec': {
            'Format': 'S3BatchOperations_CSV_20180820',
            'Fields': ['Bucket', 'Key']
        },
        'Location': {
            'ObjectArn': f'arn:aws:s3:::{INVENTORY_BUCKET}/manifests/cleanup-manifest.csv',
            'ETag': s3.get_object(Bucket=INVENTORY_BUCKET, Key='manifests/cleanup-manifest.csv')['ETag']
        }
    },
    'Report': {
        'Bucket': f'arn:aws:s3:::{BATCH_REPORT_BUCKET}',
        'Format': 'Report_CSV_20180820',
        'Enabled': True,
        'Prefix': 'batch-reports/',
        'ReportScope': 'AllTasks'
    },
    'Priority': 10,  # High
    'RoleArn': BATCH_ROLE_ARN
}

job_response = s3control.create_job(**job_config)
job_id = job_response['Job']['JobId']
print(f"Batch Job created: {job_id}")
print(f"Monitor at: https://s3.console.aws.amazon.com/batch/?region={boto3.Session().region_name}&jobId={job_id}")
